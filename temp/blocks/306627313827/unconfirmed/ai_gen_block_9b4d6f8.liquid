{% doc %}
  @prompt
    In the NOIR Hero section, apply an animated gradient color effect to only the word "attitude" in the headline text. The animation should cycle through premium, vibrant colors (like gold, purple, rose, cyan) in a smooth looping animation. Do not change the color or style of any other text like "wear". Use CSS keyframe animations with a gradient text effect for a luxurious, premium feel.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gradient-hero-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-gradient-hero__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.2;
    font-weight: {{ block.settings.font_weight }};
  }

  .ai-gradient-hero__animated-word-{{ ai_gen_id }} {
    background: linear-gradient(
      90deg,
      {{ block.settings.gradient_color_1 }},
      {{ block.settings.gradient_color_2 }},
      {{ block.settings.gradient_color_3 }},
      {{ block.settings.gradient_color_4 }},
      {{ block.settings.gradient_color_1 }}
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: ai-gradient-shift-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-in-out infinite;
    display: inline-block;
  }

  @keyframes ai-gradient-shift-{{ ai_gen_id }} {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .ai-gradient-hero__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin-top: {{ block.settings.subtext_spacing }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-gradient-hero__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-gradient-hero__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-gradient-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h1 class="ai-gradient-hero__headline-{{ ai_gen_id }}">
    {% if block.settings.headline_before != blank %}
      {{ block.settings.headline_before }}
    {% endif %}
    <span class="ai-gradient-hero__animated-word-{{ ai_gen_id }}">{{ block.settings.animated_word }}</span>
    {% if block.settings.headline_after != blank %}
      {{ block.settings.headline_after }}
    {% endif %}
  </h1>
  
  {% if block.settings.subtext != blank %}
    <div class="ai-gradient-hero__subtext-{{ ai_gen_id }}">
      {{ block.settings.subtext }}
    </div>
  {% endif %}
</div>

