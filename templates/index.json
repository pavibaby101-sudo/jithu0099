      "blocks": {
        "stat_1": { "type": "stat", "settings": { "number": "100", "suffix": "K+", "label": "Happy Customers" } },
        "stat_2": { "type": "stat", "settings": { "number": "50", "suffix": "+",  "label": "Countries Shipped" } },
        "stat_3": { "type": "stat", "settings": { "number": "5",   "suffix": "★",  "label": "Average Rating" } },
