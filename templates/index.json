      "type": "noir-editorial-grid",
      "name": "NOIR Editorial Grid",
      "settings": { "title": "Shop by Edit" },
      "blocks": {
        "item_1": { "type": "item", "settings": { "title": "Outerwear", "cta": "Shop Now" } },
        "item_2": { "type": "item", "settings": { "title": "Knitwear",  "cta": "Shop Now" } },
        "item_3": { "type": "item", "settings": { "title": "Footwear",  "cta": "Shop Now" } }
