      "type": "noir-faq",
      "name": "NOIR FAQ",
      "settings": { "eyebrow": "Got questions?", "title": "Frequently Asked", "text": "Everything you need to know before you order." },
      "blocks": {
        "q1": { "type": "item", "settings": { "question": "How long does shipping take?", "answer": "<p>Standard shipping takes 5–8 business days. Express is 2–3.</p>" } },
        "q2": { "type": "item", "settings": { "question": "What is your return policy?",  "answer": "<p>30-day returns on all unworn items. We provide a prepaid return label.</p>" } },
        "q3": { "type": "item", "settings": { "question": "Do you ship internationally?", "answer": "<p>Yes — we ship to 50+ countries. International orders over $200 ship free.</p>" } },
        "q4": { "type": "item", "settings": { "question": "How do I care for my garment?", "answer": "<p>Cold wash, inside out, hang dry. Detailed care instructions come with every order.</p>" } }
      },
      "block_order": ["q1", "q2", "q3", "q4"]
    },
    "newsletter": {
      "type": "noir-newsletter",
      "name": "NOIR Newsletter",
      "settings": {
        "eyebrow": "Stay in the loop",
        "title": "Join the list",
        "text": "Be the first to know about new drops, exclusive offers, and restocks.",
