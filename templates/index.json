      "type": "noir-heritage",
      "name": "NOIR Heritage Timeline",
      "settings": { "eyebrow": "The journey", "title": "Heritage" },
      "blocks": {
        "e1": { "type": "event", "settings": { "year": "2018", "title": "Founded",          "text": "A single seam in a small atelier." } },
        "e2": { "type": "event", "settings": { "year": "2020", "title": "First drop",       "text": "Sold out in 48 hours." } },
        "e3": { "type": "event", "settings": { "year": "2022", "title": "Worldwide shipping","text": "We started shipping to 50+ countries." } },
        "e4": { "type": "event", "settings": { "year": "2024", "title": "100K customers",   "text": "A milestone we don't take lightly." } },
        "e5": { "type": "event", "settings": { "year": "2026", "title": "Next chapter",     "text": "An ongoing study in form, fabric, and intent." } }
      },
      "block_order": ["e1", "e2", "e3", "e4", "e5"]
