    "divider_2": { "type": "noir-divider", "name": "NOIR Divider" },
    "testimonials": {
      "type": "noir-testimonials",
      "name": "NOIR Testimonials",
      "settings": { "eyebrow": "Voices", "title": "What they say" },
      "blocks": {
        "t1": { "type": "testimonial", "settings": { "quote": "The fit, the fabric, the way it makes me feel. ATTITUDE is the only label I reach for.", "author": "Aria Mendoza", "role": "Verified buyer — Los Angeles" } },
        "t2": { "type": "testimonial", "settings": { "quote": "I've owned a lot of hoodies. None of them feel like this. None of them look like this either.", "author": "Theo K.", "role": "Verified buyer — Berlin" } },
        "t3": { "type": "testimonial", "settings": { "quote": "Fast shipping, beautiful packaging, and the piece itself is a work of art. Worth every rupee.", "author": "Sana Iyer", "role": "Verified buyer — Mumbai" } }
      },
      "block_order": ["t1", "t2", "t3"]
    },
    "dual_marquee": {
      "type": "noir-dual-marquee",
      "name": "NOIR Dual Marquee",
      "settings": { "text_items": "New Collection | Free Shipping | Limited Edition | Bold Vision" }
    },
