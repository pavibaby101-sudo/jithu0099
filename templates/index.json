/*
 * ATTITUDE — Home page template
 * Premium order: Hero (fullscreen) -> USP -> Press -> Intro -> Featured Collection
 * -> Divider -> Mission/Vision -> Stats -> Features -> Media with Content
 * -> Editorial Grid -> Lookbook -> Product List -> Heritage Timeline
 * -> Divider -> Testimonials -> Dual Marquee -> FAQ -> Newsletter
 */
{
  "sections": {
    "hero": {
      "type": "noir-hero",
      "name": "NOIR Hero",
      "settings": {
        "image": "",
        "video": "",
        "headline_1": "Style",
        "headline_2": "Vibe",
        "headline_3": "Reflect",
        "subline": "Add a little bit of body text",
        "button_label": "Shop Now",
        "button_link": "shopify://collections/all",
        "show_scroll_indicator": true
      }
    },
    "usp": {
      "type": "noir-usp",
      "name": "NOIR USP Icons Row",
      "blocks": {
        "shipping": { "type": "item", "settings": { "icon": "truck", "title": "Free Shipping", "text": "On orders over $200" } },
        "returns": { "type": "item", "settings": { "icon": "return", "title": "30-Day Returns", "text": "No questions asked" } },
        "secure":  { "type": "item", "settings": { "icon": "shield", "title": "Secure Payment", "text": "256-bit SSL encryption" } },
        "support": { "type": "item", "settings": { "icon": "clock", "title": "24/7 Support", "text": "Always here for you" } }
      },
      "block_order": ["shipping", "returns", "secure", "support"]
    },
    "press": {
      "type": "noir-press",
      "name": "NOIR Press",
      "settings": { "eyebrow": "As featured in" },
      "blocks": {
        "l1": { "type": "logo", "settings": { "name": "VOGUE" } },
        "l2": { "type": "logo", "settings": { "name": "HYPEBEAST" } },
        "l3": { "type": "logo", "settings": { "name": "HIGH SNOBIETY" } },
        "l4": { "type": "logo", "settings": { "name": "DAZED" } },
        "l5": { "type": "logo", "settings": { "name": "i-D" } }
      },
      "block_order": ["l1", "l2", "l3", "l4", "l5"]
    },
    "intro": {
      "type": "noir-intro",
      "name": "NOIR Intro",
      "settings": {
        "title": "Designed to Disrupt",
        "text": "Luxury staples for the modern disruptor. Precision-tailored pieces that break convention and redefine presence. This isn't just fashion — it's a statement."
      }
    },
    "featured_collection": {
      "type": "noir-featured-collection",
      "name": "NOIR Featured Collection",
      "settings": {
        "title": "Designed to Disrupt",
        "collection": "all",
        "products_to_show": 4,
        "columns_desktop": 4
      }
    },
    "divider_1": { "type": "noir-divider", "name": "NOIR Divider" },
    "mission_vision": {
      "type": "noir-mission-vision",
      "blocks": {
        "mission": {
          "type": "row",
          "settings": {
            "eyebrow": "Our Mission",
            "title": "Crafted to Outlast",
            "text": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
            "image": "",
            "image_position": "left",
            "button_label": "Learn More",
            "button_link": "shopify://pages/about"
          }
        },
        "vision": {
          "type": "row",
          "settings": {
            "eyebrow": "Our Vision",
            "title": "Made for the Modern",
            "text": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
            "image": "",
            "image_position": "right",
            "button_label": "Learn More",
            "button_link": "shopify://pages/about"
          }
        }
