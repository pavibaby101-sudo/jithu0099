{%- comment -%}
  NOIR Dual Marquee — text + image rows, scroll in opposite directions
{%- endcomment -%}

{%- liquid
  assign text_items_raw = section.settings.text_items | default: 'New Collection | Free Shipping | Limited Edition | Bold Vision'
  assign text_items = text_items_raw | split: '|'
-%}

<section class="noir-dual-marquee" {{ section.shopify_attributes }}>
  {%- if text_items.size > 0 -%}
    <div class="noir-dual-marquee__text">
      <div class="noir-dual-marquee__track-text">
        {%- for i in (1..2) -%}
          {%- for item in text_items -%}
            {%- assign trimmed = item | strip -%}
            {%- if trimmed != blank -%}
              <span class="noir-dual-marquee__item">{{ trimmed }}</span>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="noir-dual-marquee__imgs">
      <div class="noir-dual-marquee__track-imgs">
        {%- for i in (1..2) -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.image != blank -%}
              <div
                class="noir-dual-marquee__img"
                style="background-image: url('{{ block.settings.image | image_url: width: 600 }}');"
                {{ block.shopify_attributes }}
              ></div>
            {%- else -%}
              <div class="noir-dual-marquee__img" {{ block.shopify_attributes }}></div>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "NOIR Dual Marquee",
  "tag": "section",
  "class": "noir-dual-marquee-section",
  "settings": [
    {
      "type": "textarea",
      "id": "text_items",
      "label": "Text items",
      "info": "Separate each with a | (pipe) character.",
      "default": "New Collection | Free Shipping | Limited Edition | Bold Vision"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "NOIR Dual Marquee"
    }
  ]
}
{% endschema %}
