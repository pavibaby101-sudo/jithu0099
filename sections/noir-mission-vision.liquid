{%- comment -%}
  NOIR Mission / Vision — Alternating image + text rows
  Add up to 6 blocks per section. Each block is one row.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  <section class="noir-mv" {{ section.shopify_attributes }}>
    {%- for block in section.blocks -%}
      {%- liquid
        assign reverse = false
        if block.settings.image_position == 'right'
          assign reverse = true
        endif
      -%}
      <div
        class="noir-mv__row{% if reverse %} noir-mv__row--reverse{% endif %} noir-reveal"
        {{ block.shopify_attributes }}
      >
        <div class="noir-mv__media">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1400 }}"
              alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        <div class="noir-mv__content">
          {%- if block.settings.eyebrow != blank -%}
            <p class="noir-mv__eyebrow">{{ block.settings.eyebrow }}</p>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h2 class="noir-mv__title">{{ block.settings.title }}</h2>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="noir-mv__text">{{ block.settings.text }}</div>
          {%- endif -%}

          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link | default: '#' }}" class="noir-mv__button">
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "NOIR Mission / Vision",
  "tag": "section",
  "class": "noir-mv-section",
  "settings": [],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "Our Mission"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Crafted to Outlast"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Body",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "NOIR Mission / Vision",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "eyebrow": "Our Mission",
            "title": "Crafted to Outlast",
            "image_position": "left",
            "button_label": "Learn More"
          }
        },
        {
          "type": "row",
          "settings": {
            "eyebrow": "Our Vision",
            "title": "Made for the Modern",
            "image_position": "right",
            "button_label": "Learn More"
          }
        }
      ]
    }
  ]
}
{% endschema %}
