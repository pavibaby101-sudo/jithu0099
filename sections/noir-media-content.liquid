{%- comment -%}
  NOIR Media with Content — Fullbleed image with overlay text on the left
{%- endcomment -%}

<section
  class="noir-media-content"
  {{ section.shopify_attributes }}
>
  {%- if section.settings.image != blank -%}
    <div class="noir-media-content__bg">
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="lazy"
      >
    </div>
  {%- else -%}
    <div class="noir-media-content__bg" style="background: linear-gradient(135deg, #1a1a1a, #0a0a0a);"></div>
  {%- endif -%}

  <div class="noir-media-content__overlay"></div>

  <div class="noir-media-content__inner noir-slide-left">
    {%- if section.settings.eyebrow != blank -%}
      <p class="noir-media-content__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="noir-media-content__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="noir-media-content__text">{{ section.settings.text }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="noir-media-content__button"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "NOIR Media with Content",
  "tag": "section",
  "class": "noir-media-content-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Recommended: 2000x1200 dark editorial image."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Editorial"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Beyond the season"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body",
      "default": "An ongoing study in form, fabric, and intent. We don't follow the calendar."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Discover"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "NOIR Media with Content"
    }
  ]
}
{% endschema %}
